ORMAL\", \"INTER\", \"ADV\", \"MASTER\", \"GM\"];\nconst VALS = [0, 1, 5, 3, 3, 9, 100];\nconst SCORE_MAP = [0, 1, 3, 3, 5, 9, 0];\n\n// --- 2. FAST DRAWING ---\nfunction drawPiece(p: number, x: number, y: number) {\n    let c = (p > 0) ? 1 : 15; let ap = Math.abs(p);\n    screen.fillRect(x + 3, y + 10, 9, 2, c);\n    if (ap == 1) { screen.fillRect(x + 6, y + 4, 3, 3, c); screen.fillRect(x + 5, y + 7, 5, 3, c); }\n    else if (ap == 2) { screen.fillRect(x + 4, y + 3, 7, 7, c); screen.fillRect(x + 4, y + 1, 2, 2, c); screen.fillRect(x + 9, y + 1, 2, 2, c); }\n    else if (ap == 3) { screen.fillRect(x + 5, y + 3, 5, 7, c); screen.fillRect(x + 3, y + 4, 3, 3, c); }\n    else if (ap == 4) { screen.fillRect(x + 6, y + 2, 3, 8, c); screen.fillCircle(x + 7, y + 3, 2, c); }\n    else if (ap == 5) { screen.fillRect(x + 4, y + 4, 7, 6, c); screen.fillRect(x + 6, y + 1, 3, 2, c); }\n    else if (ap == 6) { screen.fillRect(x + 5, y + 3, 5, 7, c); screen.fillRect(x + 7, y + 0, 1, 4, c); }\n}\n\n// --- 3. EFFICIENT LOGIC ---\nfunction canMove(x1: number, y1: number, x2: number, y2: number, b: number[][]): boolean {\n    if (x2 < 0 || x2 > 7 || y2 < 0 || y2 > 7) return false;\n    let p = Math.abs(b[y1][x1]); if (p == 0) return false;\n    let dx = Math.abs(x2 - x1); let dy = Math.abs(y2 - y1);\n    if (b[y2][x2] != 0 && (b[y1][x1] > 0 == b[y2][x2] > 0)) return false;\n    if (p == 2 || p == 4 || p == 5) {\n        let sdx = x2 == x1 ? 0 : (x2 > x1 ? 1 : -1), sdy = y2 == y1 ? 0 : (y2 > y1 ? 1 : -1);\n        if (p == 2 && dx != 0 && dy != 0) return false;\n        if (p == 4 && dx != dy) return false;\n        if (p == 5 && dx != dy && dx != 0 && dy != 0) return false;\n        let tx = x1 + sdx, ty = y1 + sdy;\n        while (tx != x2 || ty != y2) { if (b[ty][tx] != 0) return false; tx += sdx; ty += sdy; }\n        return true;\n    }\n    if (p == 1) {\n        let dir = (b[y1][x1] > 0) ? -1 : 1;\n        if (dx == 0 && (y2 - y1) == dir && b[y2][x2] == 0) return true;\n        if (dx == 0 && (y2 - y1) == 2 * dir && b[y2][x2] == 0 && (y1 == 6 || y1 == 1) && b[y1 + dir][x1] == 0) return true;\n        if (dx == 1 && (y2 - y1) == dir && b[y2][x2] != 0) return true;\n        return false;\n    }\n    return (p == 3) ? ((dx == 2 && dy == 1) || (dx == 1 && dy == 2)) : (p == 6 && dx <= 1 && dy <= 1);\n}\n\nfunction isLegal(x1: number, y1: number, x2: number, y2: number): boolean {\n    if (!canMove(x1, y1, x2, y2, board)) return false;\n    let side = board[y1][x1] > 0 ? 1 : -1;\n    let tmp = board[y2][x2]; board[y2][x2] = board[y1][x1]; board[y1][x1] = 0;\n    let safe = true; let kx = -1, ky = -1;\n    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++) if (board[r][c] == side * 6) { kx = c; ky = r; }\n    if (kx != -1) {\n        for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++) {\n            if (board[r][c] != 0 && (board[r][c] > 0 != side > 0)) { if (canMove(c, r, kx, ky, board)) { safe = false; break; } }\n        }\n    }\n    board[y1][x1] = board[y2][x2]; board[y2][x2] = tmp; return safe;\n}\n\n// --- 4. OPTIMIZED AI ---\nfunction aiMove() {\n    let moves: number[][] = []; let side = playerColor == 1 ? -1 : 1;\n    for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) {\n        if (board[y][x] * side > 0) {\n            for (let ty = 0; ty < 8; ty++) for (let tx = 0; tx < 8; tx++) {\n                if (isLegal(x, y, tx, ty)) {\n                    let s = SCORE_MAP[Math.abs(board[ty][tx])] * 100;\n                    s += (3.5 - Math.abs(3.5 - tx)) * 5;\n                    moves.push([x, y, tx, ty, s]);\n                }\n            }\n        }\n    }\n    if (moves.length > 0) {\n        moves.sort((a, b) => b[4] - a[4]);\n        let m = moves[Math.randomRange(0, Math.min(moves.length - 1, 10 - dIdx * 2))];\n        aiScore += SCORE_MAP[Math.abs(board[m[3]][m[2]])];\n        board[m[3]][m[2]] = board[m[1]][m[0]]; board[m[1]][m[0]] = 0;\n    } else { status = \"WIN!\"; elo += 25; }\n    turn = playerColor;\n}\n\n// --- 5. RENDER & UI ---\ngame.onPaint(function () {\n    screen.fill(11);\n    if (state == \"MENU\") {\n        screen.print(\"A: START | B: PUZZLE\", 20, 40, 1);\n        screen.print(\"ELO: \" + elo, 50, 55, 6);\n        screen.print(\"LEVEL: \" + DIFF_NAMES[dIdx], 35, 70, 5);\n    } else {\n        for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) {\n            let c = (x + y) % 2 == 0 ? 13 : 7;\n            if (sx == x && sy == y) c = 5;\n            if (hintMove.length > 0 && x == hintMove[0] && y == hintMove[1]) c = 10;\n            screen.fillRect(x * 15 + 4, y * 14 + 4, 15, 14, c);\n            if (board[y][x] != 0) drawPiece(board[y][x], x * 15 + 6, y * 14 + 4);\n        }\n        screen.fillRect(124, 0, 36, 120, 15);\n        screen.print(status, 125, 10, 2);\n        screen.print(\"ELO\", 125, 30, 1); screen.print(\"\" + elo, 125, 40, 6);\n        screen.print(\"P:\" + pScore, 125, 65, 6); screen.print(\"AI:\" + aiScore, 125, 80, 2);\n        screen.drawRect(cx * 15 + 4, cy * 14 + 4, 15, 14, 1);\n    }\n})\n\ncontroller.A.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (state == \"MENU\") { state = \"PLAY\"; initBoard(); }\n    else if (turn == playerColor) {\n        if (sx == -1) { if (board[cy][cx] * playerColor > 0) { sx = cx; sy = cy; } }\n        else {\n            if (isLegal(sx, sy, cx, cy)) {\n                let cap = SCORE_MAP[Math.abs(board[cy][cx])];\n                pScore += cap; status = cap > 0 ? \"8/10\" : \"5/10\";\n                board[cy][cx] = board[sy][sx]; board[sy][sx] = 0;\n                sx = -1; sy = -1; turn *= -1; aiMove();\n            } else { sx = -1; sy = -1; }\n        }\n    }\n})\n\ncontroller.B.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (state != \"MENU\" && turn == playerColor) {\n        let moves: number[][] = [];\n        for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) if (board[y][x] * playerColor > 0)\n            for (let ty = 0; ty < 8; ty++) for (let tx = 0; tx < 8; tx++) if (isLegal(x, y, tx, ty)) moves.push([x, y, tx, ty, SCORE_MAP[Math.abs(board[ty][tx])]]);\n        if (moves.length > 0) { moves.sort((a, b) => b[4] - a[4]); hintMove = [moves[0][0], moves[0][1]]; cx = moves[0][2]; cy = moves[0][3]; }\n    }\n})\n\nfunction initBoard() {\n    board = []; for (let i = 0; i < 8; i++) board.push([0, 0, 0, 0, 0, 0, 0, 0]);\n    let s = [2, 3, 4, 5, 6, 4, 3, 2]; for (let i = 0; i < 8; i++) { board[7][i] = s[i]; board[6][i] = 1; board[1][i] = -1; board[0][i] = -s[i]; }\n    pScore = 0; aiScore = 0; status = \"GO!\"; sx = -1; sy = -1; hintMove = [];\n}\n\ncontroller.left.onEvent(ControllerButtonEvent.Pressed, function () { if (state == \"MENU\") dIdx = Math.max(0, dIdx - 1); else if (cx > 0) cx--; })\ncontroller.right.onEvent(ControllerButtonEvent.Pressed, function () { if (state == \"MENU\") dIdx = Math.min(5, dIdx + 1); else if (cx < 7) cx++; })\ncontroller.up.onEvent(ControllerButtonEvent.Pressed, function () { if (cy > 0) cy--; })\ncontroller.down.onEvent(ControllerButtonEvent.Pressed, function () { if (cy < 7) cy++; })","README.md":" ","assets.json":"","pxt.json":"{\n    \"name\": \"Chess\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1773611774705,"editorVersion":"4.0.12","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"xtQcdR9we`oWn/}`g5-H\">ap</variable><variable id=\"tZFQ1p#iW_Vc}qBqa1nZ\">c</variable><variable id=\"hU-F:E2vs,ok`=@1aG|Z\">p</variable><variable id=\")4GZy.{?0EoA!wZyaMXW\">dx</variable><variable id=\"1eSgPbniUzsNj_6QPvD-\">dy</variable><variable id=\"|2W|a]cnXP{Ms9$@b/x:\">tx</variable><variable id=\"W!;icmhuTl}$5w3SIlFu\">sdx</variable><variable id=\",s-(YS%^0fU.w5!8Tp,/\">ty</variable><variable id=\"90q%[B)B[mc)``{vIV[I\">sd