eld></shadow></value><next><block type=\"lists_index_set\"><value name=\"LIST\"><block type=\"lists_index_get\"><value name=\"LIST\"><block type=\"variables_get\"><field name=\"VAR\" id=\"3pXbrxCApdWW93sLU[@x\">board</field></block></value><value name=\"INDEX\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value></block></value><value name=\"INDEX\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"Go+7}l7kh}*t?4k.xW[A\">j</field></block></value><value name=\"VALUE\"><block type=\"math_arithmetic\"><field name=\"OP\">MINUS</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"lists_index_get\"><value name=\"LIST\"><block type=\"variables_get\"><field name=\"VAR\" id=\"V;B3UOg|@%e|QMj=DP~n\">setup</field></block></value><value name=\"INDEX\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"Go+7}l7kh}*t?4k.xW[A\">j</field></block></value></block></value></block></value></block></next></block></next></block></next></block></statement></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"// ==========================================\n// 👑 CHESS GM: INFINITE KING EDITION v183.0\n// LEGENDARY SCORING + NEGAMAX DEPTH\n// ==========================================\n\nconst SQ = 15; const OFF_X = 2; const OFF_Y = 4;\nconst DIFF_NAMES = [\"NOVICE\", \"CASUAL\", \"INTER\", \"EXPERT\", \"MASTER\", \"GM\"];\n// Updated Values: P:1, N:3, B:3, R:5, Q:9, K: INFINITY\nconst VALS = [0, 1, 5, 3, 3, 9, 10 ** 30];\n\nlet board: number[][] = [];\nlet state = \"MENU\"; let turn = 1; let dIdx = 5; let pCol = 1;\nlet cx = 4, cy = 6; let sx = -1, sy = -1;\nlet pScore = 0, aiScore = 0; let elo = 1200; let status = \"READY\";\n\nlet animP = 0, animX1 = 0, animY1 = 0, animX2 = 0, animY2 = 0, animStep = -1;\n\nfunction printCenter(txt: string, y: number, color: number) {\n    screen.print(txt, 80 - (txt.length * 3), y, color);\n}\n\n// --- 1. VISUALS ---\nfunction drawPiece(p: number, x: number, y: number) {\n    let c = (p > 0) ? 1 : 15; let ap = Math.abs(p);\n    screen.fillRect(x + 3, y + 10, 9, 2, c);\n    if (ap == 1) { screen.fillRect(x + 6, y + 4, 3, 2, c); screen.fillRect(x + 5, y + 6, 5, 4, c); }\n    else if (ap == 2) { screen.fillRect(x + 4, y + 2, 7, 8, c); screen.fillRect(x + 3, y + 1, 2, 2, c); screen.fillRect(x + 9, y + 1, 2, 2, c); }\n    else if (ap == 3) { screen.fillRect(x + 5, y + 2, 5, 8, c); screen.fillRect(x + 3, y + 3, 3, 4, c); }\n    else if (ap == 4) { screen.fillCircle(x + 7, y + 4, 3, c); screen.fillRect(x + 6, y + 6, 3, 5, c); }\n    else if (ap == 5) { screen.fillRect(x + 4, y + 4, 7, 6, c); screen.setPixel(x + 7, y + 1, c); }\n    else if (ap == 6) { screen.fillRect(x + 5, y + 3, 5, 7, c); screen.fillRect(x + 7, y + 0, 1, 4, c); }\n}\n\n// --- 2. RULES ENGINE ---\nfunction canMove(x1: number, y1: number, x2: number, y2: number, b: number[][]): boolean {\n    if (x2 < 0 || x2 > 7 || y2 < 0 || y2 > 7) return false;\n    let p1 = b[y1][x1], p2 = b[y2][x2];\n    if (p1 == 0 || (p2 != 0 && (p1 > 0 == p2 > 0))) return false;\n    let ap = Math.abs(p1), dx = Math.abs(x2 - x1), dy = Math.abs(y2 - y1);\n    if (ap == 1) {\n        let dir = (p1 > 0) ? -1 : 1;\n        if (dx == 0 && (y2 - y1) == dir && p2 == 0) return true;\n        if (dx == 0 && (y2 - y1) == 2 * dir && p2 == 0 && (y1 == 1 || y1 == 6) && b[y1 + dir][x1] == 0) return true;\n        return (dx == 1 && (y2 - y1) == dir && p2 != 0);\n    }\n    if (ap == 2 || ap == 4 || ap == 5) {\n        if (ap == 2 && dx != 0 && dy != 0) return false;\n        if (ap == 4 && dx != dy) return false;\n        if (ap == 5 && dx != dy && dx != 0 && dy != 0) return false;\n        let sx = x2 == x1 ? 0 : (x2 > x1 ? 1 : -1), sy = y2 == y1 ? 0 : (y2 > y1 ? 1 : -1);\n        let tx = x1 + sx, ty = y1 + sy;\n        while (tx != x2 || ty != y2) { if (b[ty][tx] != 0) return false; tx += sx; ty += sy; }\n        return true;\n    }\n    return (ap == 3) ? (dx * dy == 2) : (ap == 6 && dx <= 1 && dy <= 1);\n}\n\nfunction isCheck(side: number, b: number[][]): boolean {\n    let kx = -1, ky = -1;\n    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++) if (b[r][c] == side * 6) { kx = c; ky = r; }\n    if (kx == -1) return false;\n    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++)\n        if (b[r][c] != 0 && (b[r][c] > 0 != side > 0) && canMove(c, r, kx, ky, b)) return true;\n    return false;\n}\n\nfunction isLegal(x1: number, y1: number, x2: number, y2: number, b: number[][]): boolean {\n    if (!canMove(x1, y1, x2, y2, b)) return false;\n    let side = b[y1][x1] > 0 ? 1 : -1, tmp = b[y2][x2];\n    b[y2][x2] = b[y1][x1]; b[y1][x1] = 0;\n    let safe = !isCheck(side, b);\n    b[y1][x1] = b[y2][x2]; b[y2][x2] = tmp;\n    return safe;\n}\n\n// --- 3. NEGAMAX AI ---\nfunction evaluate(b: number[][]): number {\n    let s = 0;\n    for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) {\n        let p = b[y][x]; if (p == 0) continue;\n        let v = VALS[Math.abs(p)];\n        v += (3 - Math.abs(3.5 - x)) + (3 - Math.abs(3.5 - y));\n        s += (p > 0 ? v : -v);\n    }\n    return s;\n}\n\nfunction negamax(depth: number, b: number[][], side: number, alpha: number, beta: number): number {\n    if (depth == 0) return evaluate(b) * side;\n    let max = -Infinity;\n    for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) {\n        if (b[y][x] * side > 0) {\n            for (let ty = 0; ty < 8; ty++) for (let tx = 0; tx < 8; tx++) {\n                if (isLegal(x, y, tx, ty, b)) {\n                    let tmp = b[ty][tx]; b[ty][tx] = b[y][x]; b[y][x] = 0;\n                    let v = -negamax(depth - 1, b, -side, -beta, -alpha);\n                    b[y][x] = b[ty][tx]; b[ty][tx] = tmp;\n                    if (v > max) max = v;\n                    alpha = Math.max(alpha, v);\n                    if (alpha >= beta) return alpha;\n                }\n            }\n        }\n    }\n    return max;\n}\n\nfunction getGMmove(side: number): number[] {\n    let bestV = -Infinity; let bestM = null;\n    let d = (dIdx > 4) ? 2 : 1;\n    for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) {\n        if (board[y][x] * side > 0) {\n            for (let ty = 0; ty < 8; ty++) for (let tx = 0; tx < 8; tx++) {\n                if (isLegal(x, y, tx, ty, board)) {\n                    let tmp = board[ty][tx]; board[ty][tx] = board[y][x]; board[y][x] = 0;\n                    let v = -negamax(d, board, -side, -Infinity, Infinity);\n                    board[y][x] = board[ty][tx]; board[ty][tx] = tmp;\n                    if (v > bestV) { bestV = v; bestM = [x, y, tx, ty]; }\n                }\n            }\n        }\n    }\n    return bestM;\n}\n\n// --- 4. GAME ENGINE ---\nfunction initBoard(puzzle: boolean) {\n    board = []; for (let i = 0; i < 8; i++) board.push([0, 0, 0, 0, 0, 0, 0, 0]);\n    if (puzzle) { board[0][4] = -6; board[7][4] = 6; board[1][2] = -5; board[2][2] = 1; status = \"DAILY PUZZLE\"; }\n    else {\n        let s = [2, 3, 4, 5, 6, 4, 3, 2];\n        for (let i = 0; i < 8; i++) { board[7][i] = s[i]; board[6][i] = 1; board[1][i] = -1; board[0][i] = -s[i]; }\n        status = \"YOUR TURN\";\n    }\n    pScore = 0; aiScore = 0; turn = 1; animStep = -1;\n}\n\ngame.onPaint(function () {\n    screen.fill(11);\n    if (state == \"MENU\") {\n        printCenter(\"ULTIMATE CHESS\", 20, 1); printCenter(\"A: START | B: PUZZLE\", 50, 15);\n        printCenter(\"< \" + DIFF_NAMES[dIdx] + \" >\", 80, 5); printCenter(\"ELO: \" + elo, 100, 6);\n    } else {\n        for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) {\n            let c = (x + y) % 2 == 0 ? 13 : 7;\n            if (Math.abs(board[y][x]) == 6 && isCheck(board[y][x] > 0 ? 1 : -1, board)) c = 2;\n            screen.fillRect(x * SQ + OFF_X, y * 14 + OFF_Y, SQ, 14, c);\n            if (board[y][x] != 0) drawPiece(board[y][x], x * SQ + 4, y * 14 + 4);\n        }\n        if (sx != -1) screen.drawRect(sx * SQ + OFF_X, sy * 14 + OFF_Y, SQ, 14, 4);\n        if (animStep >= 0) {\n            let ix = animX1 + (animX2 - animX1) * animStep / 10, iy = animY1 + (animY2 - animY1) * animStep / 10;\n            drawPiece(animP, ix, iy); animStep++;\n            if (animStep > 10) { board[Math.floor((animY2 - 4) / 14)][Math.floor((animX2 - 4) / SQ)] = animP; animStep = -1; }\n        }\n        screen.fillRect(122, 0, 38, 120, 15);\n        screen.print(status, 124, 10, 2);\n        screen.print(\"P:\" + (pScore > 1000 ? \"K\" : pScore), 124, 40, 6);\n        screen.print(\"AI:\" + (aiScore > 1000 ? \"K\" : aiScore), 124, 50, 2);\n        screen.drawRect(cx * SQ + OFF_X, cy * 14 + OFF_Y, SQ, 14, 1);\n    }\n})\n\ncontroller.A.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (state == \"MENU\") { state = \"PLAY\"; initBoard(false); }\n    else if (turn == pCol && animStep == -1) {\n        if (sx == -1) { if (board[cy][cx] * pCol > 0) { sx = cx; sy = cy; } }\n        else {\n            if (isLegal(sx, sy, cx, cy, board)) {\n                let v = Math.abs(board[cy][cx]); pScore += (v == 6 ? 1001 : VALS[v]);\n                animP = board[sy][sx]; animX1 = sx * SQ + 4; animY1 = sy * 14 + 4;\n                animX2 = cx * SQ + 4; animY2 = cy * 14 + 4; board[sy][sx] = 0; animStep = 0;\n                sx = -1; sy = -1; turn *= -1;\n                control.runInParallel(function () {\n                    pause(800); let m = getGMmove(-pCol);\n                    if (m) {\n                        let av = Math.abs(board[m[3]][m[2]]); aiScore += (av == 6 ? 1001 : VALS[av]);\n                        animP = board[m[1]][m[0]]; animX1 = m[0] * SQ + 4; animY1 = m[1] * 14 + 4;\n                        animX2 = m[2] * SQ + 4; animY2 = m[3] * 14 + 4; board[m[1]][m[0]] = 0; animStep = 0;\n                    } turn = pCol;\n                });\n            } else { sx = -1; sy = -1; }\n        }\n    }\n})\n\ncontroller.B.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (state == \"MENU\") { state = \"PLAY\"; initBoard(true); }\n    else { let h = getGMmove(pCol); if (h) { cx = h[2]; cy = h[3]; status = \"HINT\"; } }\n})\n\ncontroller.left.onEvent(ControllerButtonEvent.Pressed, function () { if (state == \"MENU\") dIdx = Math.max(0, dIdx - 1); else if (cx > 0) cx--; })\ncontroller.right.onEvent(ControllerButtonEvent.Pressed, function () { if (state == \"MENU\") dIdx = Math.min(5, dIdx + 1); else if (cx < 7) cx++; })\ncontroller.up.onEvent(ControllerButtonEvent.Pressed, function () { if (cy > 0) cy--; })\ncontroller.down.onEvent(ControllerButtonEvent.Pressed, function () { if (cy < 7) cy++; })\ncontroller.menu.onEvent(ControllerButtonEvent.Pressed, function () { state = \"MENU\"; })","README.md":" ","assets.json":"","pxt.json":"{\n    \"name\": \"Chess\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1773699013027,"editorVersion":"4.0.12","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"xtQcdR9we`oWn/}`g5-H\">ap</variable><variable id=\"tZFQ1p#iW_Vc}qBqa1nZ\">c</variable><variable id=\"hU-F:E2vs,ok`=@1aG|Z\">p</variable><variable id=\")4GZy.{?0EoA!wZyaMXW\">dx</variable><variable id=\"1eSgPbniUzsNj_6QPvD-\">dy</variable><variable id=\"|2W|a]cnXP{Ms9$@b/x:\">tx</variable><variable id=\"W!;icmhuTl}$5w3SIlFu\">sdx</variable><variable id=\",s-(YS%^0fU.w5!8Tp,/\">ty</variable><variable id=\"90q%[B)B[mc)``{vIV[I\">sdy</variable><variable id=\"y3{w,;4A;Sj|RXNd/]yA\">dir</variable><variable id=\"Q7Q}78o