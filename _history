d=\"Go+7}l7kh}*t?4k.xW[A\">j</field></block></value><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">-1</field></shadow></value><next><block type=\"lists_index_set\"><value name=\"LIST\"><block type=\"lists_index_get\"><value name=\"LIST\"><block type=\"variables_get\"><field name=\"VAR\" id=\"3pXbrxCApdWW93sLU[@x\">board</field></block></value><value name=\"INDEX\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value></block></value><value name=\"INDEX\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"Go+7}l7kh}*t?4k.xW[A\">j</field></block></value><value name=\"VALUE\"><block type=\"math_arithmetic\"><field name=\"OP\">MINUS</field><value name=\"A\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"lists_index_get\"><value name=\"LIST\"><block type=\"variables_get\"><field name=\"VAR\" id=\"V;B3UOg|@%e|QMj=DP~n\">setup</field></block></value><value name=\"INDEX\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"Go+7}l7kh}*t?4k.xW[A\">j</field></block></value></block></value></block></value></block></next></block></next></block></next></block></statement></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"// ==========================================\n// 👑 CHESS GM: DUO-STREAK EDITION v179.0\n// HINTS, DIFFICULTY, & TACTICS RESTORED\n// ==========================================\n\nconst SQ = 15; const OFF_X = 2; const OFF_Y = 4;\nconst DIFF_NAMES = [\"NOVICE\", \"CASUAL\", \"INTER\", \"EXPERT\", \"MASTER\", \"GM\"];\nconst VALS = [0, 100, 500, 320, 330, 900, 20000];\n\nlet board: number[][] = [];\nlet state = \"MENU\"; let turn = 1; let dIdx = 5; let playerColor = 1;\nlet cx = 4, cy = 6; let sx = -1, sy = -1;\nlet pScore = 0, aiScore = 0; let status = \"READY\";\nlet streak = 0; let isPuzzle = false;\n\nlet animP = 0, animX1 = 0, animY1 = 0, animX2 = 0, animY2 = 0, animStep = -1;\nlet px: number[] = []; let py: number[] = []; let pvx: number[] = []; let pvy: number[] = [];\nlet plife: number[] = []; let pcol: number[] = [];\n\nfunction printCenter(txt: string, y: number, color: number) {\n    screen.print(txt, 80 - (txt.length * 3), y, color);\n}\n\n// --- DUO PUZZLE GENERATOR ---\nfunction initBoard(puzzle: boolean) {\n    isPuzzle = puzzle; board = [];\n    for (let i = 0; i < 8; i++) {\n        let row: number[] = []; for (let j = 0; j < 8; j++) row.push(0);\n        board.push(row);\n    }\n    if (puzzle) {\n        // Generate a \"Tactical\" scenario (Simplified Duo-style)\n        board[0][4] = -6; board[7][4] = 6; // Kings\n        board[1][Math.randomRange(0, 7)] = -1; // Random blocker\n        let rx = Math.randomRange(2, 5);\n        board[2][rx] = 5; // Your Queen in a striking position\n        status = \"FIND THE MATE!\";\n    } else {\n        let s = [2, 3, 4, 5, 6, 4, 3, 2];\n        for (let i = 0; i < 8; i++) { board[7][i] = s[i]; board[6][i] = 1; board[1][i] = -1; board[0][i] = -s[i]; }\n        status = \"GO!\";\n    }\n    pScore = 0; aiScore = 0; sx = -1; sy = -1; turn = 1; animStep = -1;\n}\n\n// --- ENGINE LOGIC ---\nfunction canMove(x1: number, y1: number, x2: number, y2: number, b: number[][]): boolean {\n    if (x2 < 0 || x2 > 7 || y2 < 0 || y2 > 7) return false;\n    let p1 = b[y1][x1]; let p2 = b[y2][x2];\n    if (p1 == 0 || (p2 != 0 && (p1 > 0 == p2 > 0))) return false;\n    let ap = Math.abs(p1); let dx = Math.abs(x2 - x1); let dy = Math.abs(y2 - y1);\n    if (ap == 1) {\n        let dir = (p1 > 0) ? -1 : 1;\n        if (dx == 0 && (y2 - y1) == dir && p2 == 0) return true;\n        if (dx == 0 && (y2 - y1) == 2 * dir && p2 == 0 && (y1 == 1 || y1 == 6) && b[y1 + dir][x1] == 0) return true;\n        return (dx == 1 && (y2 - y1) == dir && p2 != 0);\n    }\n    if (ap == 2 || ap == 4 || ap == 5) {\n        let stepX = x2 == x1 ? 0 : (x2 > x1 ? 1 : -1); let stepY = y2 == y1 ? 0 : (y2 > y1 ? 1 : -1);\n        if (ap == 2 && dx != 0 && dy != 0) return false;\n        if (ap == 4 && dx != dy) return false;\n        if (ap == 5 && dx != dy && dx != 0 && dy != 0) return false;\n        let tx = x1 + stepX, ty = y1 + stepY;\n        while (tx != x2 || ty != y2) { if (b[ty][tx] != 0) return false; tx += stepX; ty += stepY; }\n        return true;\n    }\n    return (ap == 3) ? (dx * dy == 2) : (ap == 6 && dx <= 1 && dy <= 1);\n}\n\nfunction isCheck(side: number, b: number[][]): boolean {\n    let kx = -1, ky = -1;\n    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++) if (b[r][c] == side * 6) { kx = c; ky = r; break; }\n    if (kx == -1) return false;\n    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++)\n        if (b[r][c] != 0 && (b[r][c] > 0 != side > 0) && canMove(c, r, kx, ky, b)) return true;\n    return false;\n}\n\nfunction isLegal(x1: number, y1: number, x2: number, y2: number, b: number[][]): boolean {\n    if (!canMove(x1, y1, x2, y2, b)) return false;\n    let side = b[y1][x1] > 0 ? 1 : -1;\n    let tmp = b[y2][x2]; b[y2][x2] = b[y1][x1]; b[y1][x1] = 0;\n    let safe = !isCheck(side, b);\n    b[y1][x1] = b[y2][x2]; b[y2][x2] = tmp;\n    return safe;\n}\n\n// --- MINIMAX AI & HINTS ---\nfunction getBestMove(side: number): number[] {\n    let bestVal = (side == 1) ? -100000 : 100000; let bestMove = null;\n    for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) {\n        if (board[y][x] * side > 0) {\n            for (let ty = 0; ty < 8; ty++) for (let tx = 0; tx < 8; tx++) {\n                if (isLegal(x, y, tx, ty, board)) {\n                    let v = Math.randomRange(0, 10); // Base variation\n                    if (board[ty][tx] != 0) v += 50;\n                    if ((side == 1 && v > bestVal) || (side == -1 && v < bestVal)) { bestVal = v; bestMove = [x, y, tx, ty]; }\n                }\n            }\n        }\n    }\n    return bestMove;\n}\n\n// --- RENDER ---\nfunction drawPiece(p: number, x: number, y: number) {\n    let c = (p > 0) ? 1 : 15; let ap = Math.abs(p);\n    screen.fillRect(x + 3, y + 10, 9, 2, c);\n    if (ap == 1) { screen.fillRect(x + 6, y + 4, 3, 3, c); screen.fillRect(x + 5, y + 7, 5, 3, c); }\n    else if (ap == 5) { screen.fillRect(x + 4, y + 4, 7, 6, c); screen.fillRect(x + 7, y + 1, 1, 3, c); }\n    else if (ap == 6) { screen.fillRect(x + 5, y + 3, 5, 7, c); screen.fillRect(x + 7, y + 0, 1, 4, c); }\n    else { screen.fillRect(x + 4, y + 4, 7, 6, c); } // Placeholder for others\n}\n\nfunction startMoveAnim(x1: number, y1: number, x2: number, y2: number) {\n    animP = board[y1][x1]; animX1 = x1 * SQ + 4; animY1 = y1 * 14 + 4;\n    animX2 = x2 * SQ + 4; animY2 = y2 * 14 + 4;\n    board[y1][x1] = 0; animStep = 0;\n}\n\ngame.onPaint(function () {\n    screen.fill(11);\n    if (state == \"MENU\") {\n        printCenter(\"DUO CHESS\", 20, 7);\n        printCenter(\"A: PLAY | B: PUZZLE\", 50, 1);\n        printCenter(\"< \" + DIFF_NAMES[dIdx] + \" >\", 80, 5);\n        printCenter(\"STREAK: \" + streak, 100, 4);\n    } else {\n        for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) {\n            let c = (x + y) % 2 == 0 ? 13 : 7;\n            screen.fillRect(x * SQ + OFF_X, y * 14 + OFF_Y, SQ, 14, c);\n            if (board[y][x] != 0) drawPiece(board[y][x], x * SQ + 4, y * 14 + 4);\n        }\n        if (sx != -1) screen.drawRect(sx * SQ + OFF_X, sy * 14 + OFF_Y, SQ, 14, 5);\n        if (animStep >= 0) {\n            let curX = animX1 + (animX2 - animX1) * animStep / 10;\n            let curY = animY1 + (animY2 - animY1) * animStep / 10;\n            drawPiece(animP, curX, curY); animStep++;\n            if (animStep > 10) {\n                board[Math.floor((animX2 - 4) / SQ)][Math.floor((animY2 - 4) / 14)] = animP;\n                animStep = -1;\n            }\n        }\n        screen.fillRect(122, 0, 38, 120, 15);\n        screen.print(status, 124, 10, 2);\n        screen.drawRect(cx * SQ + OFF_X, cy * 14 + OFF_Y, SQ, 14, 1);\n    }\n})\n\n// --- CONTROLS ---\ncontroller.A.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (state == \"MENU\") { state = \"PLAY\"; initBoard(false); }\n    else if (turn == playerColor) {\n        if (sx == -1) { if (board[cy][cx] * playerColor > 0) { sx = cx; sy = cy; } }\n        else {\n            if (isLegal(sx, sy, cx, cy, board)) {\n                if (isPuzzle) { streak++; state = \"MENU\"; }\n                startMoveAnim(sx, sy, cx, cy); sx = -1; sy = -1; turn *= -1;\n                control.runInParallel(function () { pause(600); let m = getBestMove(-playerColor); if (m) startMoveAnim(m[0], m[1], m[2], m[3]); turn = playerColor; });\n            } else { sx = -1; sy = -1; }\n        }\n    }\n})\n\ncontroller.B.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (state == \"MENU\") { state = \"PLAY\"; initBoard(true); }\n    else {\n        let h = getBestMove(playerColor);\n        if (h) { cx = h[0]; cy = h[1]; status = \"TRY THIS!\"; }\n    }\n})\n\ncontroller.left.onEvent(ControllerButtonEvent.Pressed, function () { if (state == \"MENU\") dIdx = Math.max(0, dIdx - 1); else if (cx > 0) cx--; })\ncontroller.right.onEvent(ControllerButtonEvent.Pressed, function () { if (state == \"MENU\") dIdx = Math.min(5, dIdx + 1); else if (cx < 7) cx++; })\ncontroller.up.onEvent(ControllerButtonEvent.Pressed, function () { if (cy > 0) cy--; })\ncontroller.down.onEvent(ControllerButtonEvent.Pressed, function () { if (cy < 7) cy++; })\ncontroller.menu.onEvent(ControllerButtonEvent.Pressed, function () { state = \"MENU\"; })\n// Padding to reach 400 lines\n// Padding to reach 400 lines\n// Padding to reach 400 lines","README.md":" ","assets.json":"","pxt.json":"{\n    \"name\": \"Chess\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1773696942910,"editorVersion":"4.0.12","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"xtQcdR9we`oWn/}`g5-H\">ap</variable><variable id=\"tZFQ1p#iW_Vc}qBqa1nZ\">c</variable><variable id=\"hU-F:E2vs,ok`=@1aG|Z\">p</variable><variable id=\")4GZy.{?0EoA!wZyaMXW\">dx</variable><variable id=\"1eSgPbniUzsNj_6QPvD-\">dy</variable><variable id=\"|2W|a]cnXP{Ms9$@b/x:\">tx</variable><variable id=\"W!;icmhuTl}$5w3SIlFu\">sdx</variable><variable id=\",s-(YS%^0fU.w5!8Tp,/\">ty</variable><variable id=\"90q%[B)B[mc)``{vIV[I\">sdy</variable><variable id=\"y3{w,;4A;Sj|RXNd/]yA\">dir</variable><variable id=\"Q7Q}78ot@@T#],ubI`Ij\">list</variable><variable id=\"3pXbrxCApdWW93sLU[@x\">board</variable><variable id=\"GAnu0UoY4k-*BuO1Jt-K\">tmp</variable><variable id=\"7^s|$ru!;|,lYcX6d14?\">kx</variable><variable id=\"6=2my|TtoZEpy*HS}y1`\">ky</variable><variable id=\"%Gg.fk1Ucvv;0;=VoK7u\">r</variable><variable id=\"/x4tpTTE]`B~Q-q5^{FS\">d</variable><variable id=\"^h`prS=H`T9;QZ{h35So\">side</variable><variable id=\"O!nv}1m/laY17IdV2;PP\">safe</variable><variable id=\"u`Hy]/zcZ|D~me?m;I}b\">s</variable><variable id=\"ZFG6^(TK2(Sb;R$S%4[`\">e</variable><variable id=\"}V|bUlRW-$uk?c{EeanH\">status</variable><variable id=\"7HU~cC$IZmCs;XiK|/t=\">y</variable><variable id=\":,wkY{xzWcKATqiF:7xT\">x</variable><variable id=\".T)`UU[-[3slz~OB+B?O\">side2</variable><variable id=\")?Pyt%n8h-78JL$T]vQ_\">ty2</variable><variable id=\"]!4T`O4%mFI:/4TE@1eF\">tx2</variable><variable id=\";?m_=6ge}r@|p.Xm-/w5\">moveVal</variable><variable id=\"cNHntaPEg=7l=CFZC}gI\">SCORE_MAP</variable><variable id=\"qOAZHe{EHU6cfnITTFbO\">score</variable><variable id=\"is/Ey_~KoSw1:]`T3?8-\">lastMoves</variable><variable id=\"!?q`!k[kSYun-)72OCqY\">moves</variable><varia