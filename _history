ir = (b[y1][x1] * playerColor > 0) ? -1 : 1\n        if (dx == 0 && (y2 - y1) == dir && b[y2][x2] == 0) return true\n        if (dx == 0 && (y2 - y1) == 2 * dir && b[y2][x2] == 0 && (y1 == 6 || y1 == 1)) return true\n        if (dx == 1 && (y2 - y1) == dir && b[y2][x2] != 0) return true\n        return false\n    }\n    if (p == 2) return dx == 0 || dy == 0\n    if (p == 3) return (dx == 2 && dy == 1) || (dx == 1 && dy == 2)\n    if (p == 4) return dx == dy\n    if (p == 5) return dx == dy || dx == 0 || dy == 0\n    if (p == 6) return dx <= 1 && dy <= 1\n    return false\n}\n\nfunction isCheck(side: number, b: number[][]): boolean {\n    let kx = -1, ky = -1\n    for (let y = 0; y < 8; y++) {\n        for (let x = 0; x < 8; x++) { if (b[y][x] == side * 6) { kx = x; ky = y } }\n    }\n    if (kx == -1) return false\n    for (let y = 0; y < 8; y++) {\n        for (let x = 0; x < 8; x++) {\n            if (b[y][x] != 0 && (b[y][x] > 0 != side > 0)) {\n                if (canMove(x, y, kx, ky, b)) return true\n            }\n        }\n    }\n    return false\n}\n\nfunction isLegal(x1: number, y1: number, x2: number, y2: number): boolean {\n    if (!canMove(x1, y1, x2, y2, board)) return false\n    let side = board[y1][x1] > 0 ? 1 : -1\n    let temp = board[y2][x2]\n    board[y2][x2] = board[y1][x1]; board[y1][x1] = 0\n    let check = isCheck(side, board)\n    board[y1][x1] = board[y2][x2]; board[y2][x2] = temp\n    return !check\n}\n\nfunction aiMove() {\n    let moves: number[][] = []\n    for (let y = 0; y < 8; y++) {\n        for (let x = 0; x < 8; x++) {\n            if (board[y][x] != 0 && (board[y][x] > 0 == turn > 0)) {\n                for (let ty = 0; ty < 8; ty++) {\n                    for (let tx = 0; tx < 8; tx++) { if (isLegal(x, y, tx, ty)) moves.push([x, y, tx, ty, 0]) }\n                }\n            }\n        }\n    }\n    if (moves.length == 0) { gameOver = true; status = \"MATE\"; return }\n\n    for (let m of moves) { m[4] = vals[Math.abs(board[m