th_number\"><field name=\"NUM\">0</field></shadow><block type=\"text\"><field name=\"TEXT\">PLAY</field></block></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\"is/Ey_~KoSw1:]`T3?8-\">lastMoves</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"lists_create_with\"><mutation items=\"0\" horizontalafter=\"3\"></mutation></block></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\"V;B3UOg|@%e|QMj=DP~n\">setup</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"lists_create_with\" inline=\"false\"><mutation items=\"8\" horizontalafter=\"3\"></mutation><value name=\"ADD0\"><shadow type=\"math_number\"><field name=\"NUM\">2</field></shadow></value><value name=\"ADD1\"><shadow type=\"math_number\"><field name=\"NUM\">3</field></shadow></value><value name=\"ADD2\"><shadow type=\"math_number\"><field name=\"NUM\">4</field></shadow></value><value name=\"ADD3\"><shadow type=\"math_number\"><field name=\"NUM\">5</field></shadow></value><value name=\"ADD4\"><shadow type=\"math_number\"><field name=\"NUM\">6</field></shadow></value><value name=\"ADD5\"><shadow type=\"math_number\"><field name=\"NUM\">4</field></shadow></value><value name=\"ADD6\"><shadow type=\"math_number\"><field name=\"NUM\">3</field></shadow></value><value name=\"ADD7\"><shadow type=\"math_number\"><field name=\"NUM\">2</field></shadow></value></block></value><next><block type=\"pxt_controls_for\"><value name=\"VAR\"><block type=\"variables_get_reporter\" deletable=\"false\"><field name=\"VAR\" id=\"Go+7}l7kh}*t?4k.xW[A\">j</field></block></value><value name=\"TO\"><shadow type=\"math_whole_number\"><field name=\"NUM\">0</field></shadow><block type=\"math_number\"><field name=\"NUM\">7</field></block></value><statement name=\"DO\"><block type=\"lists_index_set\"><value name=\"LIST\"><block type=\"lists_index_get\"><value name=\"LIST\"><block type=\"variables_