(x1: number, y1: number, x2: number, y2: number, b: number[][]): boolean {\n    if (x2 < 0 || x2 > 7 || y2 < 0 || y2 > 7) return false;\n    let p = Math.abs(b[y1][x1]); if (p == 0) return false;\n    let dx = Math.abs(x2 - x1); let dy = Math.abs(y2 - y1);\n    if (b[y2][x2] != 0 && (b[y1][x1] > 0 == b[y2][x2] > 0)) return false;\n    if (p == 1) {\n        let dir = (b[y1][x1] > 0) ? -1 : 1;\n        if (dx == 0 && (y2 - y1) == dir && b[y2][x2] == 0) return true;\n        if (dx == 0 && (y2 - y1) == 2 * dir && b[y2][x2] == 0 && (y1 == 6 || y1 == 1) && b[y1 + dir][x1] == 0) return true;\n        return (dx == 1 && (y2 - y1) == dir && b[y2][x2] != 0);\n    }\n    if (p == 2 || p == 4 || p == 5) {\n        if (p == 2 && dx != 0 && dy != 0) return false;\n        if (p == 4 && dx != dy) return false;\n        if (p == 5 && dx != dy && dx != 0 && dy != 0) return false;\n        let sdx = x2 == x1 ? 0 : (x2 > x1 ? 1 : -1), sdy = y2 == y1 ? 0 : (y2 > y1 ? 1 : -1);\n        let tx = x1 + sdx, ty = y1 + sdy;\n        while (tx != x2 || ty != y2) { if (b[ty][tx] != 0) return false; tx += sdx; ty += sdy; }\n        return true;\n    }\n    return (p == 3) ? (dx * dy == 2) : (p == 6 && dx <= 1 && dy <= 1);\n}\n\nfunction isLegal(x1: number, y1: number, x2: number, y2: number): boolean {\n    if (!canMove(x1, y1, x2, y2, board)) return false;\n    let side = board[y1][x1] > 0 ? 1 : -1;\n    let tmp = board[y2][x2]; board[y2][x2] = board[y1][x1]; board[y1][x1] = 0;\n    let kx = -1, ky = -1;\n    for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++) if (board[r][c] == side * 6) { kx = c; ky = r; }\n    let safe = true;\n    if (kx != -1) {\n        for (let r = 0; r < 8; r++) for (let c = 0; c < 8; c++)\n            if (board[r][c] != 0 && (board[r][c] > 0 != side > 0)) if (canMove(c, r, kx, ky, board)) { safe = false; break; }\n    }\n    board[y1][x1] = board[y2][x2]; board[y2][x2] = tmp; return safe;\n}\n\n// --- 4. RUTHLESS AI ---\nfunction getBestMove(side: number): number[] {\n    let moves: number[][] = [];\n    for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) {\n        if (board[y][x] * side > 0) {\n            for (let ty = 0; ty < 8; ty++) for (let tx = 0; tx < 8; tx++) {\n                if (isLegal(x, y, tx, ty)) {\n                    let oldVal = board[ty][tx];\n                    // Score = Capture Value (x100) + Center Bonus - Distance from repetition\n                    let mScore = Math.abs(oldVal) * 100 + (3.5 - Math.abs(3.5 - tx)) * 5;\n                    if (tx == lastMove[0] && ty == lastMove[1]) mScore -= 300;\n                    moves.push([x, y, tx, ty, mScore]);\n                }\n            }\n        }\n    }\n    moves.sort((a, b) => b[4] - a[4]);\n    return (moves.length > 0) ? moves[Math.randomRange(0, Math.min(moves.length - 1, 10 - dIdx * 2))] : null;\n}\n\nfunction aiMove() {\n    let m = getBestMove(playerColor == 1 ? -1 : 1);\n    if (m) {\n        lastMove = [m[0], m[1], m[2], m[3]];\n        aiScore += VALS[Math.abs(board[m[3]][m[2]])];\n        board[m[3]][m[2]] = board[m[1]][m[0]]; board[m[1]][m[0]] = 0;\n    } else { status = \"MATE!\"; elo += 50; }\n    turn = playerColor;\n}\n\n// --- 5. RENDER & INTERFACE ---\ngame.onPaint(function () {\n    screen.fill(11);\n    if (state == \"MENU\") {\n        screen.print(\"A: START | B: PUZZLE\", 25, 45, 1);\n        screen.print(\"LVL: \" + DIFF_NAMES[dIdx], 25, 60, 5);\n        screen.print(\"ELO: \" + elo, 25, 75, 6);\n    } else {\n        for (let y = 0; y < 8; y++) for (let x = 0; x < 8; x++) {\n            screen.fillRect(x * 15 + 4, y * 14 + 4, 15, 14, (x + y) % 2 == 0 ? 13 : 7);\n            if (sx == x && sy == y) screen.drawRect(x * 15 + 4, y * 14 + 4, 15, 14, 5);\n            if (board[y][x] != 0) drawPiece(board[y][x], x * 15 + 6, y * 14 + 4);\n        }\n        screen.fillRect(124, 0, 36, 120, 15);\n        screen.print(status, 126, 10, 2);\n        screen.print(\"ELO: \" + elo, 126, 30, 6);\n        screen.print(\"P:\" + pScore, 126, 50, 1);\n        screen.print(\"AI:\" + aiScore, 126, 65, 15);\n        screen.drawRect(cx * 15 + 4, cy * 14 + 4, 15, 14, 1);\n    }\n})\n\ncontroller.A.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (state == \"MENU\") { state = \"PLAY\"; initBoard(); }\n    else if (turn == playerColor) {\n        if (sx == -1) { if (board[cy][cx] * playerColor > 0) { sx = cx; sy = cy; } }\n        else {\n            if (isLegal(sx, sy, cx, cy)) {\n                let cap = Math.abs(board[cy][cx]);\n                pScore += VALS[cap];\n                status = (cap > 0) ? \"10/10\" : \"7/10\";\n                board[cy][cx] = board[sy][sx]; board[sy][sx] = 0;\n                sx = -1; sy = -1; turn *= -1; aiMove();\n            } else { sx = -1; sy = -1; }\n        }\n    }\n})\n\ncontroller.B.onEvent(ControllerButtonEvent.Pressed, function () {\n    if (state == \"PLAY\" && turn == playerColor) {\n        let h = getBestMove(playerColor);\n        if (h) { cx = h[0]; cy = h[1]; screen.drawRect(h[2] * 15 + 4, h[3] * 14 + 4, 15, 14, 10); }\n    }\n})\n\ncontroller.menu.onEvent(ControllerButtonEvent.Pressed, function () { state = \"MENU\"; })\n\nfunction initBoard() {\n    board = []; for (let i = 0; i < 8; i++) board.push([0, 0, 0, 0, 0, 0, 0, 0]);\n    let s = [2, 3, 4, 5, 6, 4, 3, 2];\n    for (let i = 0; i < 8; i++) { board[7][i] = s[i]; board[6][i] = 1; board[1][i] = -1; board[0][i] = -s[i]; }\n    pScore = 0; aiScore = 0; status = \"GO!\"; sx = -1; sy = -1;\n}\n\ncontroller.left.onEvent(ControllerButtonEvent.Pressed, function () { if (state == \"MENU\") dIdx = Math.max(0, dIdx - 1); else if (cx > 0) cx--; })\ncontroller.right.onEvent(ControllerButtonEvent.Pressed, function () { if (state == \"MENU\") dIdx = Math.min(5, dIdx + 1); else if (cx < 7) cx++; })\ncontroller.up.onEvent(ControllerButtonEvent.Pressed, function () { if (cy > 0) cy--; })\ncontroller.down.onEvent(ControllerButtonEvent.Pressed, function () { if (cy < 7) cy++; })","README.md":" ","assets.json":"","pxt.json":"{\n    \"name\": \"Chess\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1773613624429,"editorVersion":"4.0.12","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"xtQcdR9we`oWn/}`g5-H\">ap</variable><variable id=\"tZFQ1p#iW_Vc}qBqa1nZ\">c</variable><variable id=\"hU-F:E2vs,ok`=@1aG|Z\">p</variable><variable id=\")4GZy.{?0EoA!wZyaMXW\">dx</variable><variable id=\"1eSgPbniUzsNj_6QPvD-\">dy</variable><variable id=\"|2W|a]cnXP{Ms9$@b/x:\">tx</variable><variable id=\"W!;icmhuTl}$5w3SIlFu\">sdx</variable><variable id=\",s-(YS%^0fU.w5!8Tp,/\">ty</variable><variable id=\"90q%[B)B[mc)``{vIV[I\">sdy</variable><variable id=\"y3{w,;4A;Sj|RXNd/]yA\">dir</variable><variable id=\"Q7Q}78ot@@T#],ubI`Ij\">list</variable><variable id=\"3pXbrxCApdWW93sLU[@x\">board</variable><variable id=\"GAnu0UoY4k-*BuO1Jt-K\">tmp</variable><variable id=\"7^s|$ru!;|,lYcX6d14?\">kx</variable><variable id=\"6=2my|TtoZEpy*HS}y1`\">ky</variable><variable id=\"%Gg.fk1Ucvv;0;=VoK7u\">r</variable><variable id=\"/x4tpTTE]`B~Q-q5^{FS\">d</variable><variable id=\"^h`prS=H`T9;QZ{h35So\">side</variable><variable id=\"O!nv}1m/laY17IdV2;PP\">safe</variable><variable id=\"u`Hy]/zcZ|D~me?m;I}b\">s</variable><variable id=\"ZFG6^(TK2(Sb;R$S%4[`\">e</variable><variable id=\"}V|bUlRW-$uk?c{EeanH\">status</variable><variable id=\"7HU~cC$IZmCs;XiK|/t=\">y</variable><variable id=\":,wkY{xzWcKATqiF:7xT\">x</variable><variable id=\".T)`UU[-[3slz~OB+B?O\">side2</variable><variable id=\")?Pyt%n8h-78JL$T]vQ_\">ty2</variable><variable id=\"]!4T`O4%mFI:/4TE@1eF\">tx2</variable><variable id=\";?m_=6ge}r@|p.Xm-/w5\">moveVal</variable><variable id=\"cNHntaPEg=7l=CFZC}gI\">SCORE_MAP</variable><variable id=\"qOAZHe{EHU6cfnITTFbO\">score